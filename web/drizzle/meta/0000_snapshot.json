get_i.id = ip.target_institution_id GROUP BY ip.category, ip.source_institution_id, source_i.display_name, source_i.city, source_i.region, source_i.country, source_i.country_code, source_i.lat, source_i.lon, source_i.geom, ip.target_institution_id, target_i.display_name, target_i.city, target_i.region, target_i.country, target_i.country_code, target_i.lat, target_i.lon, target_i.geom",
